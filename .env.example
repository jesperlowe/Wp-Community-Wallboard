PORT=3000
WP_BASE_URL=https://eksempel.dk
WP_API_NAMESPACE=/wp-json/wp-community/v1
WP_USERNAME=wallboard
WP_APPLICATION_PASSWORD=
TIMEZONE=Europe/Copenhagen
REFRESH_SECONDS=30
COMPLETED_TASK_LIMIT=10
COMPLETED_LOOKBACK_HOURS=24
SHIFT_LOOKAHEAD_HOURS=24
SHOW_ASSIGNEES=true

# Tomt (standard): vis data for alle arrangementer med status "active".
# Kræver at WP_USERNAME-kontoen er tilføjet som DELTAGER i hvert af dem i
# wp-admin (WordPress viser kun opgaver/vagter for arrangementer kontoen
# selv er medlem af, medmindre den er en ægte WP-administrator).
# Sæt til et bestemt tal for i stedet kun at vise ét fast arrangement.
ARRANGEMENT_ID=

# Sæt til "mock" for at udvikle/teste uden forbindelse til WordPress.
# Alt andet (eller udeladt) betyder "live" mod WP_BASE_URL.
API_MODE=live
